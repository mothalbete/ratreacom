<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - RastreaFormacom</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-light bg-white shadow-sm mb-4">
  <div class="container">
    <span class="navbar-brand">Hola, <%= user.nombre %></span>
    <a href="/logout" class="btn btn-outline-danger">Cerrar sesión</a>
  </div>
</nav>

<div class="container">

  <h2 class="mb-4">Buscador</h2>

  <form action="/search" method="POST" class="mb-4">
    <div class="mb-2">
      <input 
        type="text" 
        name="query" 
        class="form-control" 
        placeholder="Buscar talleres, productos, servicios..." 
        value="<%= query || '' %>"
        required
      >
    </div>

    <div class="mb-2">
      <input 
        type="text" 
        name="city" 
        class="form-control" 
        placeholder="Ciudad (ej: Vigo)" 
        value="<%= city || '' %>"
      >
    </div>

    <button class="btn btn-success">Buscar</button>
  </form>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <% if (query) { %>
    <h4 class="mt-4">Resultados para "<%= query %>" <% if (city) { %> en "<%= city %>" <% } %></h4>
  <% } %>

  <% if (relatedCollections && relatedCollections.length > 0) { %>
    <h5 class="mt-4">Colecciones relacionadas</h5>
    <% relatedCollections.forEach(rc => { %>
      <div class="card p-2 mb-2">
        <strong><%= rc.term %></strong>
        <% if (rc.city) { %> — <%= rc.city %> <% } %>
        <a href="/search?term=<%= rc.term %>&city=<%= rc.city %>" class="btn btn-sm btn-primary mt-1">Ver colección</a>
      </div>
    <% }) %>
  <% } %>

  <% if (results) { %>

    <div class="row mt-4">

      <div class="col-md-6">
        <h5>Negocios</h5>
        <% if (results.businesses && results.businesses.length > 0) { %>
          <% results.businesses.forEach(b => { %>
            <div class="card p-3 mb-2">
              <h5><%= b.title %></h5>
              <p><%= b.address || "Dirección no disponible" %></p>
              <p>Rating: <%= b.rating || "N/A" %></p>
              <p>Tel: <%= b.phone || "No disponible" %></p>

              <% if (b.website) { %>
                <a href="<%= b.website %>" target="_blank">Web</a>
              <% } else if (b.link) { %>
                <a href="<%= b.link %>" target="_blank">Ver en Google Maps</a>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-muted">No hay negocios.</p>
        <% } %>
      </div>

      <div class="col-md-6">
        <h5>Productos</h5>
        <% if (results.products && results.products.length > 0) { %>
          <% results.products.forEach(p => { %>
            <div class="card p-3 mb-2">
              <h5><%= p.title %></h5>
              <p>Precio: <%= p.price || "No disponible" %></p>
              <a href="<%= p.product_link || p.link %>" target="_blank">Ver producto</a>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-muted">No hay productos.</p>
        <% } %>
      </div>

    </div>

  <% } %>

  <hr class="my-5">

  <h3>Mis colecciones</h3>

  <% if (collections && collections.length > 0) { %>
    <% collections.forEach(c => { %>
      <div class="card p-3 mb-2">
        <h5><%= c.term %> <% if (c.city) { %> — <%= c.city %> <% } %></h5>
        <a href="/search?term=<%= c.term %>&city=<%= c.city %>" class="btn btn-sm btn-primary mt-2">Ver colección</a>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-muted">Aún no tienes colecciones guardadas.</p>
  <% } %>

</div>

</body>
</html>
